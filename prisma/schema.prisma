// ─────────────────────────────────────────────────────────────────────────────
// GroovyMark WebX — narrow read-only Prisma client over the shared
// Content Automation database. Only the published-content models live here;
// the automation system owns writes.
// Keep models in sync with /Users/kavindugamlath/Desktop/Content Automation/
//  prisma/schema.prisma — Post, CaseStudy, Resource, LandingPage.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id   String @id
  slug String @unique
  name String
}

model Post {
  id             String   @id
  businessId     String
  contentItemId  String   @unique
  slug           String
  title          String
  excerpt        String   @default("")
  bodyMd         String
  coverImagePath String?
  inlineImages   Json     @default("[]")
  tags           String[] @default([])
  faq            Json     @default("[]")
  publishedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  metaTitle       String?
  metaDescription String?
  keywords        String[] @default([])
  focusKeyword    String?
  ogImagePath     String?
  ogImageAlt      String?
  readingMinutes  Int?
  canonicalPath   String?
  authorName      String?
  authorRole      String?
  authorUrl       String?

  @@unique([businessId, slug])
  @@index([businessId, publishedAt])
}

model CaseStudy {
  id             String   @id
  businessId     String
  contentItemId  String   @unique
  slug           String
  title          String
  clientName     String
  metric         String
  bodyMd         String
  coverImagePath String?
  publishedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  metaTitle       String?
  metaDescription String?
  keywords        String[] @default([])
  focusKeyword    String?
  ogImagePath     String?
  ogImageAlt      String?
  readingMinutes  Int?
  canonicalPath   String?
  authorName      String?
  authorRole      String?
  authorUrl       String?

  // Rich structured fields mirroring /lib/caseStudies.js — written by the
  // automation pipeline at publish, consumed by /case-studies/[slug] page
  // via the shared CaseStudyArticle component.
  subtitle         String?
  headline         String?
  shortDescription String?
  industry         String?
  location         String?
  projectType      String?
  timeline         String?
  category         String?
  tags             String[] @default([])
  problems         Json     @default("[]")
  problemCallout   String?
  solutionIntro    String?
  pillars          Json     @default("[]")
  results          Json     @default("[]")
  techDelivered    String[] @default([])
  metrics          Json     @default("[]")
  testimonial      Json?
  closing          Json?
  finalCta         Json?
  about            Json?
  imageRoster      Json     @default("[]")

  @@unique([businessId, slug])
  @@index([businessId, publishedAt])
}

model Resource {
  id             String   @id
  businessId     String
  contentItemId  String   @unique
  slug           String
  title          String
  kind           String
  bodyMd         String
  downloadPath   String?
  coverImagePath String?
  publishedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  metaTitle       String?
  metaDescription String?
  keywords        String[] @default([])
  focusKeyword    String?
  ogImagePath     String?
  ogImageAlt      String?
  readingMinutes  Int?
  canonicalPath   String?
  authorName      String?
  authorRole      String?
  authorUrl       String?

  @@unique([businessId, slug])
  @@index([businessId, publishedAt])
}

model LandingPage {
  id              String   @id
  businessId      String
  contentItemId   String   @unique
  slug            String
  title           String
  sections        Json
  publishedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  metaTitle       String?
  metaDescription String?
  keywords        String[] @default([])
  focusKeyword    String?
  ogImagePath     String?
  ogImageAlt      String?
  canonicalPath   String?

  @@unique([businessId, slug])
  @@index([businessId, publishedAt])
}
