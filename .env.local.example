# ───────────────────────────────────────────────────────────────────────────
# GroovyMark WebX — environment variables
#
# Copy this file to `.env.local` (or set the same vars in your hosting provider)
# and fill in real values.  Do NOT commit `.env.local` to git.
# ───────────────────────────────────────────────────────────────────────────

# Resend transactional email (https://resend.com)
#   1. Sign up at resend.com (free tier is generous)
#   2. Create an API key under "API Keys"
#   3. (Production) Verify your sending domain so you can send from your own
#      address. While testing, you can leave EMAIL_FROM unset to use
#      Resend's default "onboarding@resend.dev"
RESEND_API_KEY=

# Where the support tickets and quote requests are delivered.
# Defaults to webx@groovymark.com if not set.
EMAIL_TO=webx@groovymark.com

# The "From" header used on outgoing emails.
# Defaults to "GroovyMark WebX <onboarding@resend.dev>" if not set.
# Once you've verified your domain in Resend, change this to your own address:
#   EMAIL_FROM="GroovyMark WebX <webx@groovymark.com>"
EMAIL_FROM=

# ───────────────────────────────────────────────────────────────────────────
# Content Automation integration
# Connects to the shared automation Postgres (same VPS, same docker network).
# These values are READ-ONLY for this site — never write.
# ───────────────────────────────────────────────────────────────────────────

# Same DATABASE_URL you set in the Content Automation .env
DATABASE_URL=postgresql://ca:CHANGE_ME@postgres:5432/ca?schema=public

# The business this website serves. After creating it in the automation
# dashboard (/businesses), copy the id from:
#   docker compose exec postgres psql -U ca -d ca -c "select id, slug from \"Business\";"
BUSINESS_ID=

# Public URL where Caddy serves the automation assets (matches ASSETS_DOMAIN
# in the Content Automation .env). Used to build <img src=...> URLs.
ASSETS_PUBLIC_URL=https://assets.groovymark.com
